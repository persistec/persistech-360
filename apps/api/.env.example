# Template for the .env file

NODE_ENV=development
PORT=4000
WEB_APP_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://persistech-360.vercel.app
# Host execution (local NestJS process):
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/persistech_360

# Docker Compose overrides this to:
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/persistech_360

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_WORKSPACE_DOMAIN=
