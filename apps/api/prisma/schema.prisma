datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  REMOVED
}

enum AppRole {
  ADMIN
  EMPLOYEE
}

enum DimensionType {
  corporate
  departmental
  leadership
}

model User {
  id               String          @id @default(uuid())
  googleSub        String?         @map("google_sub")
  workspaceEmail   String          @unique @map("workspace_email")
  name             String
  departmentId     String?         @map("department_id")
  roleId           String?         @map("role_id")
  hierarchyLevelId String?         @map("hierarchy_level_id")
  managerId        String?         @map("manager_id")
  status           UserStatus      @default(ACTIVE)
  appRole          AppRole         @default(EMPLOYEE) @map("app_role")
  archivedAt       DateTime?       @map("archived_at")
  archivedBy       String?         @map("archived_by")
  archiveReason    String?         @map("archive_reason")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  department           Department?             @relation(fields: [departmentId], references: [id])
  role                 Role?                   @relation(fields: [roleId], references: [id])
  hierarchyLevel       HierarchyLevel?         @relation(fields: [hierarchyLevelId], references: [id])
  manager              User?                   @relation("UserManager", fields: [managerId], references: [id])
  subordinates         User[]                  @relation("UserManager")
  createdCycles        Cycle[]                 @relation("CycleCreator")
  evaluatorAssignments EvaluationAssignment[] @relation("EvaluatorAssignments")
  evaluateeAssignments EvaluationAssignment[] @relation("EvaluateeAssignments")

  @@map("users")
}

model Department {
  id                 String       @id @default(uuid())
  name               String       @unique
  parentDepartmentId String?      @map("parent_department_id")
  archivedAt         DateTime?    @map("archived_at")
  archivedBy         String?      @map("archived_by")
  archiveReason      String?      @map("archive_reason")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  parent   Department?  @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id])
  children Department[] @relation("DepartmentHierarchy")
  users    User[]
  roles    Role[]

  @@map("departments")
}

model Role {
  id               String          @id @default(uuid())
  name             String
  departmentId     String?         @map("department_id")
  hierarchyLevelId String?         @map("hierarchy_level_id")
  archivedAt       DateTime?       @map("archived_at")
  archivedBy       String?         @map("archived_by")
  archiveReason    String?         @map("archive_reason")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  department     Department?     @relation(fields: [departmentId], references: [id])
  hierarchyLevel HierarchyLevel? @relation(fields: [hierarchyLevelId], references: [id])
  users          User[]

  @@map("roles")
}

model HierarchyLevel {
  id        String   @id @default(uuid())
  name      String   @unique
  rank      Int      @unique
  archivedAt DateTime? @map("archived_at")
  archivedBy String?   @map("archived_by")
  archiveReason String? @map("archive_reason")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users User[]
  roles Role[]

  @@map("hierarchy_levels")
}

// ---------------------------------------------------------------------------
// Evaluation domain configuration
// ---------------------------------------------------------------------------

model Dimension {
  id          String        @id @default(uuid())
  name        String        @unique
  type        DimensionType
  description String?
  weight      Float         @default(1.0)
  active      Boolean       @default(true)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  criteria            Criterion[]
  applicabilityRules  ApplicabilityRule[]

  @@map("dimensions")
}

model Criterion {
  id          String   @id @default(uuid())
  dimensionId String   @map("dimension_id")
  text        String
  description String?
  weight      Float    @default(1.0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  dimension          Dimension           @relation(fields: [dimensionId], references: [id])
  options            CriterionOption[]
  applicabilityRules ApplicabilityRule[]
  answers            EvaluationAnswer[]

  @@map("criteria")
}

model CriterionOption {
  id          String   @id @default(uuid())
  criterionId String   @map("criterion_id")
  label       String
  scoreValue  Float?   @map("score_value")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  criterion Criterion @relation(fields: [criterionId], references: [id], onDelete: Cascade)
  answers   EvaluationAnswer[]

  @@map("criterion_options")
}

model ApplicabilityRule {
  id                           String   @id @default(uuid())
  // Either dimensionId or criterionId must be set (not both, not neither)
  dimensionId                  String?  @map("dimension_id")
  criterionId                  String?  @map("criterion_id")
  relationshipType             String?  @map("relationship_type")
  sameDepartmentRequired       Boolean  @default(false) @map("same_department_required")
  crossDepartmentAllowed       Boolean  @default(true) @map("cross_department_allowed")
  minHierarchyRank             Int?     @map("min_hierarchy_rank")
  maxHierarchyRank             Int?     @map("max_hierarchy_rank")
  requiredRoleFamily           String?  @map("required_role_family")
  blockedIfEvaluateeAboveEvaluator Boolean @default(true) @map("blocked_if_evaluatee_above_evaluator")
  createdAt                    DateTime @default(now()) @map("created_at")
  updatedAt                    DateTime @updatedAt @map("updated_at")

  dimension Dimension? @relation(fields: [dimensionId], references: [id], onDelete: SetNull)
  criterion Criterion? @relation(fields: [criterionId], references: [id], onDelete: SetNull)

  @@map("applicability_rules")
}

model WeightRule {
  id                    String   @id @default(uuid())
  relationshipType      String   @map("relationship_type")
  sameDepartmentWeight  Float    @default(1.0) @map("same_department_weight")
  crossDepartmentWeight Float    @default(1.0) @map("cross_department_weight")
  categoryWeight        Float    @default(1.0) @map("category_weight")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("weight_rules")
}

model RetentionPolicy {
  id                                 String   @id @default(uuid())
  name                               String   @unique
  evaluationsVisibleUntilOffset      Int      @map("evaluations_visible_until_offset")
  exportsAllowedUntilOffset          Int      @map("exports_allowed_until_offset")
  rawDataRetentionUntilOffset        Int      @map("raw_data_retention_until_offset")
  anonymizedSummaryRetentionUntilOffset Int   @map("anonymized_summary_retention_until_offset")
  createdAt                          DateTime @default(now()) @map("created_at")
  updatedAt                          DateTime @updatedAt @map("updated_at")
  cycles                             Cycle[]

  @@map("retention_policies")
}

enum CycleStatus {
  draft
  scheduled
  open
  closing_soon
  closed
  results_published
  archived
}

enum AssignmentStatus {
  pending
  completed
  locked
  cancelled
}

enum RelationshipType {
  same_department_peer
  cross_department_peer
  manager_to_subordinate
  manual_assignment
}

model Cycle {
  id                String                 @id @default(uuid())
  name              String
  description       String?
  startAt           DateTime               @map("start_at")
  endAt             DateTime               @map("end_at")
  status            CycleStatus            @default(draft)
  retentionPolicyId String?                @map("retention_policy_id")
  createdById       String?                @map("created_by_id")
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")
  retentionPolicy   RetentionPolicy?       @relation(fields: [retentionPolicyId], references: [id], onDelete: SetNull)
  createdBy         User?                  @relation("CycleCreator", fields: [createdById], references: [id], onDelete: SetNull)
  assignments       EvaluationAssignment[]

  @@map("cycles")
}

model EvaluationAssignment {
  id               String           @id @default(uuid())
  cycleId          String           @map("cycle_id")
  evaluatorId      String           @map("evaluator_id")
  evaluateeId      String           @map("evaluatee_id")
  relationshipType RelationshipType @map("relationship_type")
  status           AssignmentStatus @default(pending)
  required         Boolean          @default(true)
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  cycle            Cycle            @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  evaluator        User             @relation("EvaluatorAssignments", fields: [evaluatorId], references: [id], onDelete: Cascade)
  evaluatee        User             @relation("EvaluateeAssignments", fields: [evaluateeId], references: [id], onDelete: Cascade)
  submission       EvaluationSubmission?

  @@unique([cycleId, evaluatorId, evaluateeId])
  @@map("evaluation_assignments")
}

model EvaluationSubmission {
  id            String    @id @default(uuid())
  assignmentId  String    @unique @map("assignment_id")
  finalComment  String?   @map("final_comment")
  submittedAt   DateTime? @map("submitted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  assignment    EvaluationAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  answers       EvaluationAnswer[]

  @@map("evaluation_submissions")
}

model EvaluationAnswer {
  id                 String    @id @default(uuid())
  submissionId       String    @map("submission_id")
  criterionId        String    @map("criterion_id")
  criterionOptionId  String?   @map("criterion_option_id")
  scoreValueSnapshot Float?    @map("score_value_snapshot")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  submission         EvaluationSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  criterion          Criterion            @relation(fields: [criterionId], references: [id])
  criterionOption    CriterionOption?     @relation(fields: [criterionOptionId], references: [id])

  @@unique([submissionId, criterionId])
  @@index([criterionId])
  @@index([criterionOptionId])
  @@map("evaluation_answers")
}
